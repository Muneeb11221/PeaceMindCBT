# Required: Your Google Gemini API key
GEMINI_API_KEY=your_api_key_here

# Optional: Port the server listens on (defaults to 3000)
PORT=3000

# Optional: Your deployed frontend URL for CORS protection
# e.g. FRONTEND_URL=https://peacemind-cbt.netlify.app
FRONTEND_URL=http://localhost:8080

# Optional: Set to 'production' to enable stricter security
# NODE_ENV=production
